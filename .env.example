# GoPulley — Esempio di configurazione
# Copia questo file in .env e adatta i valori al tuo ambiente.
# Non committare mai .env con credenziali reali nel repository!

# ── Server ──────────────────────────────────────────────────────────────────
# Porta dell'applicazione (unico punto di accesso per download e admin)
APP_PORT=8080

# URL base pubblica usata per generare i link di download nella dashboard.
# Obbligatorio quando le due porte sono su host/domini diversi.
# Esempio: https://files.example.com  (senza slash finale)
PUBLIC_BASE_URL=

# ── Sicurezza ────────────────────────────────────────────────────────────────
# Genera con: openssl rand -hex 32
SESSION_SECRET=change-me-in-production-use-openssl-rand-hex-32

# ── LDAP / Active Directory ───────────────────────────────────────────────────
# Dev: LDAP_HOST=mock accetta qualsiasi credenziale
# Prod: ldap://  porta 389  oppure  ldaps://  porta 636 (TLS, consigliato)
LDAP_HOST=mock
#LDAP_HOST=ldap://dc.example.com:389
#LDAP_HOST=ldaps://dc.example.com:636

# true = ignora errori certificato (utile per CA interne / self-signed)
LDAP_TLS_SKIP_VERIFY=false

# Base DN del dominio AD
LDAP_BASE_DN=dc=example,dc=com

# Template per il DN dell'utente. %s viene sostituito con lo username al login.
# Stile UPN (Active Directory moderno):
LDAP_USER_DN_TEMPLATE=%s@example.com
# Stile DN classico (OpenLDAP / vecchio AD):
#LDAP_USER_DN_TEMPLATE=uid=%s,ou=Users,dc=example,dc=com

# Account di servizio per le query di ricerca gruppo.
# Necessario se l'utente loggato non ha permessi di lettura sulla directory.
# Lascia vuoto per usare la sessione dell'utente autenticato.
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=

# Gruppo AD richiesto per accedere (solo il CN, senza OU/DC).
# Lascia vuoto per autorizzare tutti gli utenti AD.
LDAP_REQUIRED_GROUP=

# Gruppo AD che definisce gli amministratori (vedono la route /admin).
# Lascia vuoto se non usi gruppi AD per gli admin.
LDAP_ADMIN_GROUP=

# Elenco diretto (separato da ';') degli utenti amministratori.
# Es: mario.rossi;luigi.verdi
ADMIN_USERS=

# ── Limiti ───────────────────────────────────────────────────────────────────
MAX_GLOBAL_DAYS=30
MAX_UPLOAD_SIZE_MB=2048

# Quota massima di caricamento per utente espresso in MB.
# Imposta a 0 per nessuna quota (spazio illimitato).
USER_QUOTA_MB=0

# ── Branding aziendale (opzionale) ───────────────────────────────────────────
# Mostra nome e logo dell'ente accanto al logo GoPulley (login + navbar).
# BRAND_LOGO accetta:
#   - URL esterno:  https://www.example.com/logo.png
#   - Path locale:  il file deve essere presente nella cartella /data (es. my-logo.png)
# Se lasciati vuoti, l'interfaccia rimane invariata.
#BRAND_NAME=Nome Azienda
#BRAND_LOGO=brand-logo.png

# ── Storage ──────────────────────────────────────────────────────────────────
# DATA_DIR: percorso sull'HOST che verrà montato su /data nel container.
# Cambia questo valore per spostare DB e upload su un disco diverso.
DATA_DIR=./data

# Questi percorsi sono interni al container; non cambiarli salvo esigenze specifiche.
DB_PATH=/data/gopulley.db
UPLOAD_DIR=/data/uploads

# ── Sicurezza file ────────────────────────────────────────────────────────────
# Se true, calcola e memorizza lo SHA-256 di ogni file caricato e lo mostra
# nella pagina di download, permettendo ai destinatari di verificare l'integrità.
# Default: false
#ENABLE_SHA256=true
