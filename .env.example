# GoPulley - Example configuration
# Copy this file to .env and adjust values for your environment.
# Never commit .env with real credentials to the repository!

# ── Server ──────────────────────────────────────────────────────────────────
# Application port (single entry point for download and admin)
APP_PORT=8080

# Logging level: debug, info, warn, error
LOG_LEVEL=info

# Public base URL used to generate download links in the dashboard.
# Required when ports are exposed on different hosts/domains.
# Example: https://files.example.com (without trailing slash)
PUBLIC_BASE_URL=

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-in-production-use-openssl-rand-hex-32

# Secure cookie flag: requires HTTPS for session cookies.
# Set to false ONLY when behind a reverse proxy that terminates TLS (e.g. Traefik, Nginx)
# and communicates with the app over HTTP in local network.
SECURE_COOKIES=true

# ── LDAP / Active Directory ───────────────────────────────────────────────────
# Dev: LDAP_HOST=mock accepts any credential
# Prod: ldap:// port 389 or ldaps:// port 636 (TLS recommended)
LDAP_HOST=mock
#LDAP_HOST=ldap://dc.example.com:389
#LDAP_HOST=ldaps://dc.example.com:636

# true = ignore certificate errors (useful for internal CA / self-signed)
LDAP_TLS_SKIP_VERIFY=false

# Auto-upgrade ldap:// to TLS via StartTLS. Set to false for pure plain-text
LDAP_STARTTLS=true

# AD domain base DN
LDAP_BASE_DN=dc=example,dc=com

# User DN template. %s is replaced with username on login.
# UPN style (modern Active Directory):
LDAP_USER_DN_TEMPLATE=%s@example.com
# Classic DN style (OpenLDAP / legacy AD):
#LDAP_USER_DN_TEMPLATE=uid=%s,ou=Users,dc=example,dc=com

# Service account for group lookup queries.
# Needed if logged-in users cannot search the directory.
# Leave empty to use the authenticated user's session.
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=

# AD group required to access (CN only, without OU/DC).
# Leave empty to allow all AD users.
LDAP_REQUIRED_GROUP=

# AD group defining administrators (can access /admin route).
# Leave empty if you do not use AD groups for admins.
LDAP_ADMIN_GROUP=

# Explicit list (separated by ';') of admin users.
# Example: john.doe;jane.doe
ADMIN_USERS=

# ── Limits ───────────────────────────────────────────────────────────────────
MAX_GLOBAL_DAYS=30
MAX_UPLOAD_SIZE_MB=2048

# Maximum upload quota per user in MB.
# Set to 0 for no quota (unlimited space).
USER_QUOTA_MB=0

# Chunk size for resumable uploads (in MB).
# Default: 10
UPLOAD_CHUNK_SIZE_MB=10

# Time-to-live (seconds) for in-progress upload sessions.
# Sessions automatically expire after this period of inactivity (if no keep-alive calls received).
# While an upload is in progress, the session TTL is extended automatically every
# UPLOAD_SESSION_REFRESH_SECONDS seconds, regardless of browser visibility.
# This means uploads will continue even if the browser is minimized/hidden.
# Session expires only AFTER upload completes, is cancelled, or browser closes.
# Default: 60 seconds (ensures timeout if client crashes/disconnects)
UPLOAD_SESSION_TTL_SECONDS=60

# Interval (seconds) for browser to send keep-alive requests to extend upload session TTL.
# Sent continuously while upload is active, even when browser is hidden/minimized.
# Default: 30 seconds
UPLOAD_SESSION_REFRESH_SECONDS=30

# Maximum number of concurrent in-progress upload sessions per user.
# Default: 3
# Set to 0 to disable this limit (useful behind proxies that may retry requests).
MAX_UPLOAD_SESSIONS_PER_USER=3

# Time-to-live (hours) for login session cookies.
# Users must re-authenticate after this period.
# Default: 24 hours
LOGIN_SESSION_TTL_HOURS=24

# ── Corporate branding (optional) ────────────────────────────────────────────
# Show organization name and logo next to GoPulley logo (login + navbar).
# BRAND_LOGO accepts:
#   - External URL: https://www.example.com/logo.png
#   - Local path: file must exist in /data (e.g. my-logo.png)
# If left empty, the interface remains unchanged.
#BRAND_NAME=Company Name
#BRAND_LOGO=brand-logo.png

# ── Storage ──────────────────────────────────────────────────────────────────
# DATA_DIR: HOST path mounted as /data in the container.
# Change this value to move DB and uploads to another disk.
DATA_DIR=./data

# These paths are internal to the container; do not change unless needed.
DB_PATH=/data/gopulley.db
UPLOAD_DIR=/data/uploads

# ── File security ─────────────────────────────────────────────────────────────
# If true, compute/store SHA-256 for each uploaded file and show it
# on the download page so recipients can verify integrity.
# Default: false
# ENABLE_SHA256=true

# ── Email Settings (Optional) ────────────────────────────────────────────────
# Configure SMTP settings to allow sending file share links directly via email
# from the web interface. Leave blank to disable the feature.
# SMTP_SERVER=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURITY=auto
# Allowed: auto | starttls | ssl | none
# - auto: try STARTTLS when available (backward compatible default)
# - starttls: require STARTTLS (recommended for port 587)
# - ssl: implicit TLS (typically port 465)
# - none: plain SMTP without TLS (only for trusted internal networks)
# SMTP_USER=your_username
# SMTP_PASSWORD='your_password'
# SMTP_FROM=noreply@example.com
# 
# Set SMTP_USER_AUTH=true to use the Active Directory user's email and password
# instead of the global `SMTP_USER` and `SMTP_PASSWORD`. Ideal for MS Exchange environments.
# When SMTP_USER_AUTH=false, emails are sent from the shared SMTP sender account
# and should be considered a non-monitored mailbox (no-reply behavior).
# SMTP_USER_AUTH=false
