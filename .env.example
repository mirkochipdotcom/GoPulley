# GoPulley — Esempio di configurazione
# Copia questo file in .env e adatta i valori al tuo ambiente.
# Non committare mai .env con credenziali reali nel repository!

# ── Server ──────────────────────────────────────────────────────────────────
APP_PORT=8080

# ── Sicurezza ────────────────────────────────────────────────────────────────
# Genera con: openssl rand -hex 32
SESSION_SECRET=change-me-in-production-use-openssl-rand-hex-32

# ── LDAP / Active Directory ───────────────────────────────────────────────────
# Dev: LDAP_HOST=mock accetta qualsiasi credenziale
# Prod: ldap://  porta 389  oppure  ldaps://  porta 636 (TLS, consigliato)
LDAP_HOST=mock
#LDAP_HOST=ldap://dc.example.com:389
#LDAP_HOST=ldaps://dc.example.com:636

# true = ignora errori certificato (utile per CA interne / self-signed)
LDAP_TLS_SKIP_VERIFY=false

# Base DN del dominio AD
LDAP_BASE_DN=dc=example,dc=com

# Template per il DN dell'utente. %s viene sostituito con lo username al login.
# Stile UPN (Active Directory moderno):
LDAP_USER_DN_TEMPLATE=%s@example.com
# Stile DN classico (OpenLDAP / vecchio AD):
#LDAP_USER_DN_TEMPLATE=uid=%s,ou=Users,dc=example,dc=com

# Account di servizio per le query di ricerca gruppo.
# Necessario se l'utente loggato non ha permessi di lettura sulla directory.
# Lascia vuoto per usare la sessione dell'utente autenticato.
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=

# Gruppo AD richiesto per accedere (solo il CN, senza OU/DC).
# Lascia vuoto per autorizzare tutti gli utenti AD.
LDAP_REQUIRED_GROUP=

# ── Limiti ───────────────────────────────────────────────────────────────────
MAX_GLOBAL_DAYS=30
MAX_UPLOAD_SIZE_MB=2048

# ── Storage ──────────────────────────────────────────────────────────────────
# Questi percorsi sono interni al container; monta i volumi di conseguenza.
DB_PATH=/data/gopulley.db
UPLOAD_DIR=/data/uploads
